# Docker Devin Worker Environment Variables
# Copy this file to .env.docker-devin and fill in your values
# Usage: docker run --env-file .env.docker-devin ...

# ---- Devin Provider ----
HARNESS_PROVIDER=devin
DEVIN_API_KEY=cog_...                    # Devin API key (prefix: cog_*)
DEVIN_ORG_ID=org-...                     # Devin organization ID (prefix: org-*)
# DEVIN_POLL_INTERVAL_MS=15000           # Polling interval (default: 15000ms)
# DEVIN_ACU_COST_USD=2.25               # USD per ACU for cost tracking (default: 2.25)
# DEVIN_API_BASE_URL=https://api.devin.ai  # Override for testing
# DEVIN_MAX_ACU_LIMIT=                     # Per-session ACU cap (sent to Devin API + UI budget bar)
# MAX_SKILL_CHARS=100000                   # Max chars for inlined SKILL.md (default: 100000)
# HAS_MCP=false                            # MCP support (not yet tested — keep false)

# ---- Required ----
API_KEY=your-api-key-here

# ---- Agent Identity ----
# Keep AGENT_ID stable across restarts for task resume and identity persistence
AGENT_ID=
AGENT_NAME=
AGENT_ROLE=worker

# ---- Networking ----
MCP_BASE_URL=http://host.docker.internal:3013

# ---- Behavior ----
YOLO=false
# MAX_CONCURRENT_TASKS=1

# ---- System Prompt (optional) ----
SYSTEM_PROMPT=
SYSTEM_PROMPT_FILE=

# ---- Templates (optional) ----
# TEMPLATE_ID=official/coder

# ---- Startup ----
STARTUP_SCRIPT_STRICT=true

# ---- GitHub (for git operations) ----
GITHUB_TOKEN=
GITHUB_EMAIL=worker-agent@desplega.ai
GITHUB_NAME=Worker Agent
