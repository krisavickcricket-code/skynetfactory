{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skynetfactory://schemas/gate-result/v1.0",
  "title": "SkyNetFactoryGateResult",
  "description": "Result of running acceptance gates for a module.",
  "type": "object",
  "required": ["module_id","overall_result","individual_results","timestamp"],
  "properties": {
    "module_id": { "type": "string" },
    "overall_result": { "type": "string", "enum": ["pass","fail"] },
    "individual_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gate_name","result","details"],
        "properties": {
          "gate_name": { "type": "string" },
          "result": { "type": "string", "enum": ["pass","fail","warn","skip"] },
          "details": { "type": "string" },
          "duration_ms": { "type": "number" }
        }
      }
    },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}