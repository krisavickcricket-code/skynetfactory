{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skynetfactory://schemas/sidecar/v1.1",
  "title": "SkyNetFactoryModuleSidecar",
  "description": "Sidecar metadata for a SkyNetFactory module — usage guide for consuming agents.",
  "type": "object",
  "required": ["module_id","version","purpose","agent_usage","common_calls","failure_modes","composition_tags"],
  "properties": {
    "module_id": { "type": "string", "pattern": "^[a-z0-9_]+\\.[a-z0-9_]+$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "purpose": { "type": "string", "minLength": 10 },
    "agent_usage": {
      "type": "object",
      "required": ["when_to_use","when_not_to_use"],
      "properties": {
        "when_to_use": { "type": "string", "minLength": 10 },
        "when_not_to_use": { "type": "string", "minLength": 10 },
        "example_workflow": { "type": "string" }
      }
    },
    "common_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description","method","path_or_command"],
        "properties": {
          "description": { "type": "string" },
          "method": { "type": "string" },
          "path_or_command": { "type": "string" },
          "input_example": { "type": "object" },
          "output_example": { "type": "object" }
        }
      },
      "minItems": 1
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["condition","symptom","recovery"],
        "properties": {
          "condition": { "type": "string" },
          "symptom": { "type": "string" },
          "recovery": { "type": "string" },
          "severity": { "type": "string", "enum": ["transient","permanent"], "default": "transient" }
        }
      },
      "minItems": 1
    },
    "composition_tags": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
  },
  "additionalProperties": false
}